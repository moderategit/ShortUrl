<div style="max-width: 600px; margin: 20px auto; font-family: Arial, sans-serif;">
  <h1>Short URL Created Successfully</h1>

  <div style="background: #f5f5f5; padding: 20px; border-radius: 5px; margin: 20px 0;">
    <p>
      <strong>Short URL:</strong><br>
      <code style="background: #e0e0e0; padding: 5px; border-radius: 3px;">
        <%= link_to short_url_redirect_url(path: @short_url.path), short_url_redirect_url(path: @short_url.path), target: '_blank' %>
      </code>
    </p>

    <p>
      <strong>Target URL:</strong><br>
      <%= link_to @short_url.target_url, @short_url.target_url, target: '_blank' %>
    </p>

    <p>
      <strong>Page Title:</strong><br>
      <em><%= @short_url.title %></em>
    </p>

    <p>
      <strong>Clicks:</strong> <strong><%= @click_count %></strong>
    </p>

    <p>
      <strong>Created:</strong> <%= @short_url.created_at.strftime('%Y-%m-%d %H:%M:%S') %>
    </p>
  </div>

  <div style="margin-top: 20px;">
    <%= link_to "← Create Another Short URL", new_short_url_path, class: "btn" %>
    <%= link_to "View All →", short_urls_path, class: "btn" %>
  </div>

  <% if @recent_visits.any? %>
    <div style="margin-top: 30px;">
      <h2>Recent Visits</h2>
      <table style="width: 100%; border-collapse: collapse;">
        <thead>
          <tr style="background: #f0f0f0;">
            <th style="text-align: left; padding: 10px; border-bottom: 1px solid #ddd;">IP Address</th>
            <th style="text-align: left; padding: 10px; border-bottom: 1px solid #ddd;">Location</th>
            <th style="text-align: left; padding: 10px; border-bottom: 1px solid #ddd;">Timestamp</th>
          </tr>
        </thead>
        <tbody>
          <% @recent_visits.each do |visit| %>
            <tr style="border-bottom: 1px solid #eee;">
              <td style="padding: 10px;"><code><%= visit.ip_address %></code></td>
              <td style="padding: 10px;"><%= visit.visited_at.strftime('%Y-%m-%d %H:%M:%S') %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
