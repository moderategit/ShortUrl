<div style="max-width: 1000px; margin: 20px auto; font-family: Arial, sans-serif;">
  <h1>All Short URLs</h1>

  <div style="margin: 20px 0;">
    <%= link_to "Create New Short URL", new_short_url_path, class: "btn" %>
    <%= link_to "View Usage Report", visits_index_path, class: "btn" %>
  </div>

  <% if @short_urls.any? %>
    <table style="width: 100%; border-collapse: collapse;">
      <thead>
        <tr style="background: #f0f0f0;">
          <th style="text-align: left; padding: 10px; border-bottom: 2px solid #333;">Short Path</th>
          <th style="text-align: left; padding: 10px; border-bottom: 2px solid #333;">Target URL</th>
          <th style="text-align: left; padding: 10px; border-bottom: 2px solid #333;">Clicks</th>
          <th style="text-align: left; padding: 10px; border-bottom: 2px solid #333;">Created</th>
        </tr>
      </thead>
      <tbody>
        <% @short_urls.each do |short_url| %>
          <tr style="border-bottom: 1px solid #eee;">
            <td style="padding: 10px; font-family: monospace;">
              <%= link_to short_url.path, short_url_path(short_url) %>
            </td>
            <td style="padding: 10px;">
              <%= link_to truncate(short_url.target_url, length: 50), short_url.target_url, target: '_blank' %>
            </td>
            <td style="padding: 10px; text-align: center;">
              <strong><%= short_url.visits.count %></strong>
            </td>
            <td style="padding: 10px;">
              <%= short_url.created_at.strftime('%Y-%m-%d') %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p style="color: #666; margin: 20px 0;">No short URLs created yet.</p>
    <%= link_to "Create Your First Short URL", new_short_url_path %>
  <% end %>
</div>
